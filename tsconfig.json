{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "target": "es6",
    "sourceMap": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "controllers/*": [
        "./src/controllers/*"
      ],
      "config/*": [
        "./src/config/*"
      ],
      "services/*": [
        "./src/services/*"
      ],
      "routers/*": [
        "./src/routers/*"
      ],
    }
  },
}