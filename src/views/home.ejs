<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Main Page</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>

<body>
    <div
        style="display: flex; justify-content: space-around;padding: 20px;border-radius: 12px; margin: 30px;background: aquamarine;">
        <h1>Main Page</h1>
        <a class="btn btn-primary" href="/createUser">Create User</a>
    </div>
    <div>
        <h1>List User <% users %>
        </h1>
        <br>
        <table class="table table-striped table-hover">
            <thead>
                <th>ID</th>
                <th>Name</th>
                <th>Email</th>
                <th>Address</th>
                <th>Action</th>
            </thead>
            <tbody>
                <% users.forEach((user)=> { %>
                    <tr>
                        <td>
                            <%=user.id %>
                        </td>
                        <td>
                            <%=user.name %>
                        </td>
                        <td>
                            <%=user.email %>
                        </td>
                        <td>
                            <%=user.address %>
                        </td>
                        <td>
                            <btn class="btn btn-danger">Delete</btn>
                        </td>
                    </tr>
                    <%}); %>

            </tbody>
        </table>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</body>

</html>